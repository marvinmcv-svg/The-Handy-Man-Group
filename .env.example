# Database
DATABASE_URL="file:/home/z/my-project/db/custom.db"

# Admin session token secret — REQUIRED in production.
# Generate a long random string, e.g. `openssl rand -hex 32`.
# Must be at least 32 characters and must NOT be the default value below.
ADMIN_TOKEN_SECRET="change-me-to-a-long-random-string-of-at-least-32-chars"

# Admin login credentials — REQUIRED in production.
# Defaults below are for local development only and will be rejected at
# runtime when NODE_ENV === "production".
ADMIN_USERNAME="Joeisgay123!"
ADMIN_PASSWORD="Joelewis123!"

# Public site URL — used for canonical URLs, OpenGraph, sitemap & robots.
# In production this should be your real domain.
NEXT_PUBLIC_SITE_URL="https://thehandymangroup.com.au"
