// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model QuoteRequest {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  service     String
  message     String
  suburb      String?
  status      String   @default("new")
  notes       String?  // internal admin notes
  quoteAmount String?  // quoted dollar amount (string to avoid float issues)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id        String   @id @default(cuid())
  title     String
  blurb     String
  icon      String
  points    String // JSON array of strings
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  category    String
  location    String
  description String
  image       String
  video       String?  // optional video URL for project
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  quote     String
  video     String?  // optional video URL (uploaded media or external)
  image     String?  // optional poster/thumbnail image URL
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Faq {
  id        String   @id @default(cuid())
  q         String
  a         String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminSession {
  id        String   @id @default(cuid())
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Media {
  id            String   @id @default(cuid())
  filename      String   // stored filename on disk
  originalName  String   // original upload name
  mimeType      String
  size          Int      // bytes
  url           String   // /uploads/xxx.jpg
  type          String   // "image" | "video"
  width         Int?
  height        Int?
  createdAt     DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String   // JSON-encoded value
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String   // e.g. "create", "update", "delete", "login"
  entity    String   // e.g. "service", "project", "quote", "media"
  entityId  String?
  detail    String?
  createdAt DateTime @default(now())
}
